# ============================================
# CADMarket — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ----- Frontend (Vite) -----
# Vite exposes env vars prefixed with VITE_ to client-side code

# API base URL (backend server)
VITE_API_URL=https://cadmarket.onrender.com/api

# Razorpay key (public key, safe for client-side)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ----- Backend (Node.js / Express) -----

# Server port
PORT=5000

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/cadmarket

# JWT secret for admin authentication
JWT_SECRET=your_jwt_secret_here_change_in_production

# JWT token expiry
JWT_EXPIRES_IN=2

# ----- Razorpay -----

# Razorpay API credentials (server-side, keep secret)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ----- Cloudinary -----

# Cloudinary credentials for image & file storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

